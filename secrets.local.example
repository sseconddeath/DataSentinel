# Скопируйте этот файл в secrets.local и впишите свои ключи.
# secrets.local — в .gitignore и НЕ коммитится в репозиторий.
#
# Ключи нужны только для сборки .exe (build.bat вызывает build_inject.py inject
# перед PyInstaller'ом). Из исходников приложение тоже может работать —
# тогда ключи можно ввести через настройки в самом UI после первого запуска,
# либо оставить пустыми и пользоваться источниками, которым ключи не нужны.
#
# Получить ключи:
#   - Groq:    https://console.groq.com/keys           (бесплатно)
#   - RapidAPI: https://rapidapi.com/                  (нужен для Hudson Rock, EmailRep, BreachDirectory)
#   - IntelX:  https://intelx.io/account?tab=developer (есть free tier)

GROQ_API_KEY=gsk_your_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
INTELX_API_KEY=your_intelx_uuid_here
